# .env.jest

# Jest-only env vars for local testing (no secrets).

PORT=8080
NODE_ENV=development

# Enable Basic Auth in tests
HTPASSWD_FILE=tests/.htpasswd

# JWT config (this API expects: Authorization: jwt <token>)
JWT_SECRET=test-secret-key

# Mongo (not required for the auth-focused unit tests, but used by server.js)
MONGODB_URL=mongodb://localhost:27017/fincraft-test

# OpenAI (controllers may import it)
OPENAI_API_KEY=test-key
